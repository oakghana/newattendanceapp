# ============================================================
# Environment Variables — copy to .env.local for development
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (used in email notification links)
APP_URL=https://updates.qccapps.com
NEXT_PUBLIC_APP_URL=https://updates.qccapps.com

# SMTP Email Configuration (required for workflow email notifications)
# For Gmail: enable 2FA, then generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password
